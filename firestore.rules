rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Projects: anyone can read, authenticated users can write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users/freelancers: anyone can read, owner or backend can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Vaults: anyone can read (for escrow display), authenticated write
    match /vaults/{vaultId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
